# HuggingFace token used only during weight download (not needed at runtime).
HF_TOKEN=

# Cloudflare R2 credentials (S3-compatible).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Optional custom public base (e.g. https://media.example.com). If unset,
# signed URLs are generated against the R2 endpoint.
R2_PUBLIC_BASE=

# Path on the attached network volume where weights live (see scripts/download_weights.sh).
LTX_WEIGHTS_ROOT=/workspace/models

# Optional. If set to one of i2v|a2v|distilled, the matching pipeline is
# instantiated at cold start instead of lazily on first request.
LTX_DEFAULT_PIPELINE=

# Presigned URL TTL in seconds (default 24h).
LTX_SIGNED_URL_TTL=86400

# Optional LoRA strength for the distilled lora attached to i2v / a2v (default 0.6).
LTX_DISTILLED_LORA_STRENGTH=0.6
